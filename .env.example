# RegPipeline — environment template. Copy to .env and fill in. NEVER commit .env.

# --- Google Cloud / Gemini 3 (REQUIRED by hackathon rules) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-west1
GOOGLE_GENAI_USE_VERTEXAI=true
GEMINI_MODEL=gemini-3

# --- Fivetran (partner) ---
FIVETRAN_API_KEY=your-fivetran-key
FIVETRAN_API_SECRET=your-fivetran-secret
# Route Fivetran calls through the REAL Fivetran MCP server (@getnao/fivetran-mcp-server)
# at runtime instead of REST. This is the judged "partner MCP invoked at runtime" path.
FIVETRAN_USE_MCP=true
# The Nao MCP server expects ONE base64-encoded credential = base64("key:secret").
# If unset, src/fivetran-mcp.js derives it from FIVETRAN_API_KEY/SECRET above.
# FIVETRAN_BASE_64_API_KEY=base64-of-key:secret

# --- BigQuery (regulatory data warehouse that Fivetran syncs into) ---
BQ_DATASET=regulatory
# new-regulation lookback window for the daily digest:
DIGEST_LOOKBACK_HOURS=24

# --- App ---
PORT=8080
NODE_ENV=development

# --- Demo mode: set MOCK=true to run the full UI + ApprovalBar flow with
# canned data and NO credentials (great for rehearsing the ~3-min demo). ---
# MOCK=true
